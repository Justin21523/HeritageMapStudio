{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Configure HeritageMapStudio",
      "type": "shell",
      "command": "cmake --preset linux-qt6-debug",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Build HeritageMapStudio",
      "type": "shell",
      "command": "cmake --build --preset linux-qt6-debug -j$(nproc)",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Configure HeritageMapStudio"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "Run HeritageMapStudio",
      "type": "shell",
      "command": "./build/HeritageMapStudio",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": [
        "Build HeritageMapStudio"
      ],
      "problemMatcher": []
    }
  ]
}