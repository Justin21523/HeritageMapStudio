{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 16,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "linux-qt6-debug",
            "displayName": "Linux Qt6 Debug",
            "description": "Native Linux Qt6 build using the system compiler and exported compile commands.",
            "generator": "Unix Makefiles",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "/usr/bin/c++",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_EXE_LINKER_FLAGS": "",
                "CMAKE_SHARED_LINKER_FLAGS": "",
                "CMAKE_MODULE_LINKER_FLAGS": ""
            },
            "environment": {
                "CC": "",
                "CXX": "",
                "CFLAGS": "",
                "CXXFLAGS": "",
                "CPPFLAGS": "",
                "LDFLAGS": "",
                "CMAKE_ARGS": "",
                "CMAKE_PREFIX_PATH": ""
            }
        }
    ],
    "buildPresets": [
        {
            "name": "linux-qt6-debug",
            "displayName": "Build Linux Qt6 Debug",
            "configurePreset": "linux-qt6-debug"
        }
    ]
}
